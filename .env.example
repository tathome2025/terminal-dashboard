# Terminal Dashboard for Even G2 Smart Glasses
# Copy this file to .env and fill in your values

# Beeper Bridge Manager API (local)
# Install: https://github.com/nicolo-ribaudo/beeper-mcp-server
BEEPER_URL="http://127.0.0.1:23373/v0/mcp"
BEEPER_TOKEN="your_beeper_bridge_api_token_here"

# Your custom dashboard API endpoint (optional)
# This should return JSON with: todos, events, email, jobs
# See README for the expected API response format
HUB_API_URL="https://your-hub-app.vercel.app/api/dashboard"
HUB_API_TOKEN="your_hub_api_bearer_token_here"

# RSS News feed (optional, defaults to RTHK HK local news)
NEWS_RSS_URL="https://rthk.hk/rthk/news/rss/c_expressnews_clocal.xml"

# SSH monitoring - known safe IPs (comma-separated, optional)
# These IPs will NOT trigger SSH intrusion alerts
# Example: Tailscale IPs, local network devices
SSH_KNOWN_IPS="100.x.x.x,192.168.x.x"
